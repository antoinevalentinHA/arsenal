# =========================================================
# Arsenal — GitHub Linguist Configuration
# =========================================================

# ---------------------------------------------------------
# YAML Home Assistant
# ---------------------------------------------------------

*.yaml linguist-language=YAML linguist-detectable=true
*.yml linguist-language=YAML linguist-detectable=true

# ---------------------------------------------------------
# Documentation
# ---------------------------------------------------------

*.md linguist-documentation=true

# ---------------------------------------------------------
# Home Assistant runtime
# ---------------------------------------------------------

.storage/** linguist-generated=true
.cloud/** linguist-generated=true

*.log linguist-generated=true
*.db linguist-generated=true
*.db-shm linguist-generated=true
*.db-wal linguist-generated=true

# ---------------------------------------------------------
# HACS / vendor Python code
# ---------------------------------------------------------

custom_components/** linguist-vendored=true

# ---------------------------------------------------------
# Vendored frontend resources
# ---------------------------------------------------------

www/community/** linguist-vendored=true
www/bar-card/** linguist-vendored=true
www/lovelace-layout-card/** linguist-vendored=true

# ---------------------------------------------------------
# Generated frontend bundles
# ---------------------------------------------------------

*.min.js linguist-generated=true

# ---------------------------------------------------------
# End-of-line normalization
# ---------------------------------------------------------

* text=auto

*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.json text eol=lf
*.sh   text eol=lf

*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf